// Jenkinsfile — CI/CD Pipeline для report-service
// Автор: Иванов Кирилл Константинович
// Порт: 8082 (т.к. 8080/8081/8090 заняты)
// Порядок: Test → Build → Deploy → Health (каждый только если предыдущий OK)
pipeline {
agent any
parameters {
booleanParam(
name: 'ROLLBACK_ONLY',
defaultValue: false,
description: 'Если включено — выполнить только rollback'
)
}
environment {
APP_NAME = 'report-service'
CONTAINER_NAME = 'report-service'
CONTAINER_PORT = '8082'          // 👈 Ваш порт
APP_INTERNAL_PORT = '5000'
IMAGE_TAG = "${APP_NAME}:${env.BUILD_NUMBER}"
LAST_SUCCESSFUL_FILE = 'last_successful_build.txt'
}
stages {
// 🔹 Stage 1: Test (запускается только если ROLLBACK_ONLY=false)
stage('Test') {
when {
allOf {
expression { params.ROLLBACK_ONLY == false }
expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
}
}
steps {
echo "🧪 Запуск тестов"
sh '''
echo "=== Установка зависимостей ==="
python3 -m pip install --user --break-system-packages -r requirements.txt
echo "=== Запуск pytest ==="
python3 -m pytest test_app.py -v --tb=short
echo "✅ Тесты пройдены"
'''
}
}
// 🔹 Stage 2: Build (только если Test успешен)
stage('Build') {
when {
allOf {
expression { params.ROLLBACK_ONLY == false }
expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
}
}
steps {
echo "🔨 Сборка Docker образа: ${env.IMAGE_TAG}"
sh '''
docker build -t ${IMAGE_TAG} .
echo "✓ Образ собран: ${IMAGE_TAG}"
docker images | grep ${APP_NAME}
'''
}
}
// 🔹 Stage 3: Deploy (только если Build успешен)
stage('Deploy') {
when {
allOf {
expression { params.ROLLBACK_ONLY == false }
expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
}
}
steps {
echo "🚀 Деплой на порт ${CONTAINER_PORT}"
sh '''
docker stop ${CONTAINER_NAME} 2>/dev/null || true
docker rm ${CONTAINER_NAME} 2>/dev/null || true
docker run -d \
-p ${CONTAINER_PORT}:${APP_INTERNAL_PORT} \
--name ${CONTAINER_NAME} \
${IMAGE_TAG}
echo "✓ Контейнер запущен"
sleep 3
'''
}
}
// 🔹 Stage 4: Health Check (только если Deploy успешен)
stage('Health Check') {
when {
allOf {
expression { params.ROLLBACK_ONLY == false }
expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
}
}
steps {
echo "🏥 Проверка доступности на порту ${CONTAINER_PORT}"
script {
try {
sh '''
echo "=== Health Check ==="
for i in {1..10}; do
if curl -sf http://localhost:${CONTAINER_PORT}/health > /dev/null 2>&1; then
echo "✅ Приложение доступно!"
curl -s http://localhost:${CONTAINER_PORT}/health
exit 0
fi
echo "⏳ Попытка $i/10..."
sleep 2
done
echo "❌ Health check failed"
exit 1
'''
sh "echo ${env.BUILD_NUMBER} > ${LAST_SUCCESSFUL_FILE}"
echo "✅ Build ${env.BUILD_NUMBER} сохранён как успешный"
} catch (Exception e) {
echo "❌ Health check failed: ${e.message}"
throw e
}
}
}
post {
failure {
echo "🔄 Автоматический rollback..."
script {
if (fileExists(env.LAST_SUCCESSFUL_FILE)) {
def lastBuild = readFile(env.LAST_SUCCESSFUL_FILE).trim()
def lastImage = "${APP_NAME}:${lastBuild}"
echo "🔄 Откат к версии: ${lastImage}"
sh """
docker stop ${CONTAINER_NAME} 2>/dev/null || true
docker rm ${CONTAINER_NAME} 2>/dev/null || true
if docker images | grep -q '${lastImage}'; then
docker run -d \\
-p ${CONTAINER_PORT}:${APP_INTERNAL_PORT} \\
--name ${CONTAINER_NAME} \\
${lastImage}
echo "✓ Rollback completed"
else
echo "⚠ Образ ${lastImage} не найден"
fi
"""
} else {
echo "⚠ Нет предыдущей успешной сборки для rollback"
}
}
error "Pipeline FAILED: health-check не пройден"
}
}
}
// 🔹 Rollback Only Mode (запускается независимо)
stage('Rollback') {
when { expression { params.ROLLBACK_ONLY == true } }
steps {
echo "🔄 Режим ROLLBACK_ONLY"
script {
if (fileExists(env.LAST_SUCCESSFUL_FILE)) {
def lastBuild = readFile(env.LAST_SUCCESSFUL_FILE).trim()
def lastImage = "${APP_NAME}:${lastBuild}"
echo "🔄 Rollback to: ${lastImage}"
sh """
docker stop ${CONTAINER_NAME} 2>/dev/null || true
docker rm ${CONTAINER_NAME} 2>/dev/null || true
if docker images | grep -q '${lastImage}'; then
docker run -d \\
-p ${CONTAINER_PORT}:${APP_INTERNAL_PORT} \\
--name ${CONTAINER_NAME} \\
${lastImage}
echo "✓ Rollback completed: ${lastImage}"
else
echo "⚠ Образ ${lastImage} не найден"
exit 1
fi
"""
} else {
error "Rollback failed: файл ${LAST_SUCCESSFUL_FILE} не найден"
}
}
}
}
}
post {
always {
echo "🧹 Cleanup..."
}
success { echo "✅ Pipeline SUCCESS" }
failure { echo "❌ Pipeline FAILED" }
}
}