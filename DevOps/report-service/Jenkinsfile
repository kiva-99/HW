// Jenkinsfile — CI/CD Pipeline для report-service
// Автор: Иванов Кирилл Константинович
// Агент: docker-builder (имеет Python+pip+venv И доступ к Docker хоста)
// Порт: 8082

pipeline {

    // docker-builder — единственный агент у которого есть и Python, и Docker
    agent { label 'docker-builder' }

    parameters {
        booleanParam(
            name: 'ROLLBACK_ONLY',
            defaultValue: false,
            description: 'Если включено — пропустить build/test и выполнить только rollback'
        )
    }

    environment {
        APP_NAME              = 'report-service'
        CONTAINER_NAME        = 'report-service'
        CONTAINER_PORT        = '8082'
        APP_INTERNAL_PORT     = '5000'
        IMAGE_TAG             = "${APP_NAME}:${env.BUILD_NUMBER}"
        LAST_SUCCESSFUL_FILE  = 'last_successful_build.txt'
    }

    stages {

        // ══════════════════════════════════════════════════════
        // Stage 1: Test
        // Запускаем pytest через venv прямо на агенте docker-builder
        //
        // Почему venv, а не Docker-контейнер для тестов?
        //   - На docker-builder уже есть python3 + pip + venv
        //   - venv изолирует зависимости без лишних образов
        //   - Быстрее: не нужно собирать/скачивать тестовый образ
        //   - Чище: после тестов просто удаляем папку venv
        // ══════════════════════════════════════════════════════
        stage('Test') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                dir('DevOps/report-service') {
                    echo "🧪 Запуск тестов через venv на агенте docker-builder"
                    sh '''
                        echo "=== Создаём виртуальное окружение ==="
                        python3 -m venv venv

                        echo "=== Устанавливаем зависимости из requirements.txt + pytest ==="
                        venv/bin/pip install --quiet --upgrade pip
                        venv/bin/pip install --quiet -r requirements.txt pytest

                        echo "=== Запускаем pytest ==="
                        venv/bin/pytest test_app.py -v --tb=short

                        echo "=== Убираем venv за собой ==="
                        rm -rf venv

                        echo "✅ Тесты пройдены"
                    '''
                }
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 2: Build
        // Собираем Docker образ с тегом report-service:BUILD_NUMBER
        // docker-builder видит Docker хоста через проброшенный сокет
        // ══════════════════════════════════════════════════════
        stage('Build') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                dir('DevOps/report-service') {
                    echo "🔨 Сборка Docker образа: ${env.IMAGE_TAG}"
                    sh '''
                        docker build -t ${IMAGE_TAG} .
                        echo "✓ Образ собран: ${IMAGE_TAG}"

                        # --format нужен потому что Docker Desktop (Windows)
                        # выдаёт нестандартные колонки — grep на обычном выводе ненадёжен
                        docker images --format "table {{.Repository}}:{{.Tag}}\t{{.Size}}" \
                            | grep ${APP_NAME} || true
                    '''
                }
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 3: Deploy
        // Останавливаем старый контейнер (если есть) и запускаем новый
        // || true означает "не падать если контейнера ещё нет"
        // ══════════════════════════════════════════════════════
        stage('Deploy') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                echo "🚀 Деплой контейнера на порт ${env.CONTAINER_PORT}"
                sh '''
                    echo "=== Останавливаем старый контейнер (если есть) ==="
                    docker stop ${CONTAINER_NAME} 2>/dev/null || true
                    docker rm   ${CONTAINER_NAME} 2>/dev/null || true

                    echo "=== Запускаем новый контейнер ==="
                    docker run -d \
                        -p ${CONTAINER_PORT}:${APP_INTERNAL_PORT} \
                        --name ${CONTAINER_NAME} \
                        ${IMAGE_TAG}

                    echo "✓ Контейнер запущен, ждём 3 секунды для старта приложения..."
                    sleep 3
                '''
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 4: Health Check
        // Проверяем что приложение реально отвечает на /health
        //
        // Логика:
        //   10 попыток × 2 секунды = максимум 20 секунд ожидания
        //   Если успех → сохраняем BUILD_NUMBER в файл
        //   Если провал → rollback на последнюю успешную версию → FAILED
        // ══════════════════════════════════════════════════════
        stage('Health Check') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                echo "🏥 Проверка доступности на порту ${env.CONTAINER_PORT}"
                script {
                    def healthOk = false

                    for (int i = 1; i <= 10; i++) {
                        def exitCode = sh(
                            // wget -q — тихий режим (без прогресса)
                            // -O /dev/null — ответ нам не нужен, выбрасываем
                            // wget возвращает 0 если сервер ответил, 1+ если недоступен
                            script: "wget -q -O /dev/null http://localhost:${env.CONTAINER_PORT}/health",
                            returnStatus: true   // не падать при ошибке, а вернуть код выхода
                        )

                        if (exitCode == 0) {
                            healthOk = true
                            echo "✅ Health check пройден с попытки ${i}!"
                            // wget -q -O - выводит тело ответа в stdout — покажем что вернуло приложение
                            sh "wget -q -O - http://localhost:${env.CONTAINER_PORT}/health"
                            break
                        }
                        echo "⏳ Попытка ${i}/10 неудачна, ждём 2 сек..."
                        sleep(2)
                    }

                    if (healthOk) {
                        // Сохраняем номер этой успешной сборки для будущего rollback
                        sh "echo ${env.BUILD_NUMBER} > ${env.LAST_SUCCESSFUL_FILE}"
                        echo "✅ Build ${env.BUILD_NUMBER} сохранён в ${env.LAST_SUCCESSFUL_FILE}"

                    } else {
                        // ── Автоматический rollback ──────────────────────────
                        echo "❌ Health check провалился — запускаем автоматический rollback"

                        // Сначала убираем сломанный контейнер
                        sh """
                            docker stop ${env.CONTAINER_NAME} 2>/dev/null || true
                            docker rm   ${env.CONTAINER_NAME} 2>/dev/null || true
                        """

                        if (fileExists(env.LAST_SUCCESSFUL_FILE)) {
                            def lastBuild = readFile(env.LAST_SUCCESSFUL_FILE).trim()
                            def lastImage = "${env.APP_NAME}:${lastBuild}"
                            echo "🔄 Откатываемся к образу: ${lastImage}"

                            sh """
                                # Проверяем что образ существует локально
                                # --format нужен из-за Docker Desktop (нестандартный вывод docker images)
                                FOUND=\$(docker images --format '{{.Repository}}:{{.Tag}}' | grep -x '${lastImage}' || true)

                                if [ -n "\$FOUND" ]; then
                                    docker run -d \
                                        -p ${env.CONTAINER_PORT}:${env.APP_INTERNAL_PORT} \
                                        --name ${env.CONTAINER_NAME} \
                                        ${lastImage}
                                    echo "✓ Rollback выполнен: запущен ${lastImage}"
                                else
                                    echo "⚠ Образ ${lastImage} не найден локально, rollback невозможен"
                                fi
                            """
                        } else {
                            echo "⚠ Файл ${env.LAST_SUCCESSFUL_FILE} не найден — это первая сборка, откатиться некуда"
                        }

                        // Завершаем pipeline как FAILED в любом случае
                        error("❌ Pipeline FAILED: Health check не прошёл")
                    }
                }
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 5: Rollback Only
        // Запускается ТОЛЬКО если ROLLBACK_ONLY = true
        // Читает last_successful_build.txt и поднимает ту версию
        // ══════════════════════════════════════════════════════
        stage('Rollback') {
            when {
                expression { params.ROLLBACK_ONLY == true }
            }
            steps {
                echo "🔄 Режим ROLLBACK_ONLY — ручной откат на предыдущую версию"
                script {
                    if (!fileExists(env.LAST_SUCCESSFUL_FILE)) {
                        error("❌ Rollback невозможен: файл ${env.LAST_SUCCESSFUL_FILE} не найден. Нет ни одной успешной сборки.")
                    }

                    def lastBuild = readFile(env.LAST_SUCCESSFUL_FILE).trim()
                    def lastImage = "${env.APP_NAME}:${lastBuild}"
                    echo "🔄 Откатываемся к образу: ${lastImage}"

                    sh """
                        FOUND=\$(docker images --format '{{.Repository}}:{{.Tag}}' | grep -x '${lastImage}' || true)

                        if [ -z "\$FOUND" ]; then
                            echo "❌ Образ ${lastImage} не найден локально"
                            exit 1
                        fi

                        docker stop ${env.CONTAINER_NAME} 2>/dev/null || true
                        docker rm   ${env.CONTAINER_NAME} 2>/dev/null || true

                        docker run -d \
                            -p ${env.CONTAINER_PORT}:${env.APP_INTERNAL_PORT} \
                            --name ${env.CONTAINER_NAME} \
                            ${lastImage}

                        echo "✓ Rollback выполнен: запущен ${lastImage}"
                    """
                }
            }
        }
    }

    // ══════════════════════════════════════════════════════
    // POST — выполняется всегда после завершения всех stages
    // ══════════════════════════════════════════════════════
    post {
        always {
            echo "🧹 Cleanup — подчищаем за собой"
            sh "rm -rf DevOps/report-service/venv 2>/dev/null || true"
        }
        success {
            echo "✅ Pipeline SUCCESS — сборка ${env.BUILD_NUMBER} успешна, приложение доступно на порту ${env.CONTAINER_PORT}"
        }
        failure {
            echo "❌ Pipeline FAILED — проверьте логи выше"
        }
    }
}