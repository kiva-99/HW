// Jenkinsfile — CI/CD Pipeline для report-service
// Автор: Иванов Кирилл Константинович
// Агент: docker-builder (Python+pip+venv + доступ к Docker хоста)
// Порт: 8082
// Health check: через docker exec внутрь контейнера (curl/wget на агенте нет,
//               а localhost агента ≠ localhost хоста Windows)

pipeline {

    agent { label 'docker-builder' }

    parameters {
        booleanParam(
            name: 'ROLLBACK_ONLY',
            defaultValue: false,
            description: 'Если включено — пропустить build/test и выполнить только rollback'
        )
    }

    environment {
        APP_NAME              = 'report-service'
        CONTAINER_NAME        = 'report-service'
        CONTAINER_PORT        = '8082'
        APP_INTERNAL_PORT     = '5000'
        IMAGE_TAG             = "${APP_NAME}:${env.BUILD_NUMBER}"
        LAST_SUCCESSFUL_FILE  = 'last_successful_build.txt'
    }

    stages {

        // ══════════════════════════════════════════════════════
        // Stage 1: Test
        // Запускаем pytest через venv прямо на агенте docker-builder.
        // venv изолирует зависимости: не трогаем системный Python,
        // не нужен sudo, работает на любом агенте где есть python3.
        // ══════════════════════════════════════════════════════
        stage('Test') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                dir('DevOps/report-service') {
                    echo "🧪 Запуск тестов через venv на агенте docker-builder"
                    sh '''
                        echo "=== Создаём виртуальное окружение ==="
                        python3 -m venv venv

                        echo "=== Устанавливаем зависимости ==="
                        venv/bin/pip install --quiet --upgrade pip
                        venv/bin/pip install --quiet -r requirements.txt pytest

                        echo "=== Запускаем pytest ==="
                        venv/bin/pytest test_app.py -v --tb=short

                        echo "=== Убираем venv за собой ==="
                        rm -rf venv

                        echo "✅ Тесты пройдены"
                    '''
                }
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 2: Build
        // Собираем Docker образ с тегом report-service:BUILD_NUMBER.
        // docker-builder видит Docker хоста через проброшенный сокет.
        // ══════════════════════════════════════════════════════
        stage('Build') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                dir('DevOps/report-service') {
                    echo "🔨 Сборка Docker образа: ${env.IMAGE_TAG}"
                    sh '''
                        docker build -t ${IMAGE_TAG} .
                        echo "✓ Образ собран: ${IMAGE_TAG}"

                        # --format нужен из-за Docker Desktop (Windows):
                        # стандартный вывод docker images содержит лишние колонки,
                        # grep по нему ненадёжен
                        docker images --format "table {{.Repository}}:{{.Tag}}\t{{.Size}}" \
                            | grep ${APP_NAME} || true
                    '''
                }
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 3: Deploy
        // Останавливаем старый контейнер, запускаем новый.
        // "|| true" — не падать если контейнера ещё нет (первый запуск).
        // ══════════════════════════════════════════════════════
        stage('Deploy') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                echo "🚀 Деплой контейнера на порт ${env.CONTAINER_PORT}"
                sh '''
                    echo "=== Останавливаем старый контейнер (если есть) ==="
                    docker stop ${CONTAINER_NAME} 2>/dev/null || true
                    docker rm   ${CONTAINER_NAME} 2>/dev/null || true

                    echo "=== Запускаем новый контейнер ==="
                    docker run -d \
                        -p ${CONTAINER_PORT}:${APP_INTERNAL_PORT} \
                        --name ${CONTAINER_NAME} \
                        ${IMAGE_TAG}

                    echo "✓ Контейнер запущен, ждём 3 секунды для старта приложения..."
                    sleep 3
                '''
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 4: Health Check
        //
        // ПОЧЕМУ docker exec, а не wget/curl с агента?
        //   Агент docker-builder — это контейнер на Windows.
        //   Когда он делает wget localhost:8082 — обращается к localhost
        //   ВНУТРИ своего контейнера, а порт 8082 пробросан на хост Windows,
        //   а не внутрь агента. Поэтому "Connection refused".
        //
        //   Решение: заходим ВНУТРЬ контейнера report-service через docker exec
        //   и проверяем порт 5000 (внутренний порт приложения).
        //   Внутри контейнера нет curl/wget, но есть Python — используем urllib.
        //
        // Логика:
        //   10 попыток × 2 секунды = максимум 20 секунд ожидания
        //   Успех → сохраняем BUILD_NUMBER в last_successful_build.txt
        //   Провал → rollback на последнюю успешную версию → FAILED
        // ══════════════════════════════════════════════════════
        stage('Health Check') {
            when {
                expression { params.ROLLBACK_ONLY == false }
            }
            steps {
                echo "🏥 Проверка доступности (через docker exec внутрь контейнера)"
                script {
                    def healthOk = false

                    for (int i = 1; i <= 10; i++) {
                        // Заходим внутрь контейнера report-service и делаем HTTP запрос
                        // на внутренний порт 5000 через Python urllib (curl/wget там нет)
                        def exitCode = sh(
                            script: """
                                docker exec ${env.CONTAINER_NAME} python3 -c \
                                "import urllib.request, sys
try:
    urllib.request.urlopen('http://localhost:${env.APP_INTERNAL_PORT}/health')
    sys.exit(0)
except Exception:
    sys.exit(1)"
                            """,
                            returnStatus: true  // не бросать исключение при ошибке,
                        )                       // просто вернуть код выхода

                        if (exitCode == 0) {
                            healthOk = true
                            echo "✅ Health check пройден с попытки ${i}!"
                            // Показываем реальный ответ приложения для лога
                            sh """
                                docker exec ${env.CONTAINER_NAME} python3 -c \
                                "import urllib.request
resp = urllib.request.urlopen('http://localhost:${env.APP_INTERNAL_PORT}/health')
print(resp.read().decode())"
                            """
                            break
                        }
                        echo "⏳ Попытка ${i}/10 неудачна, ждём 2 сек..."
                        sleep(2)
                    }

                    if (healthOk) {
                        // Сохраняем номер успешной сборки — он нужен для rollback
                        sh "echo ${env.BUILD_NUMBER} > ${env.LAST_SUCCESSFUL_FILE}"
                        echo "✅ Build ${env.BUILD_NUMBER} сохранён в ${env.LAST_SUCCESSFUL_FILE}"

                    } else {
                        // ── Автоматический rollback при провале health check ──
                        echo "❌ Health check провалился — запускаем автоматический rollback"

                        sh """
                            docker stop ${env.CONTAINER_NAME} 2>/dev/null || true
                            docker rm   ${env.CONTAINER_NAME} 2>/dev/null || true
                        """

                        if (fileExists(env.LAST_SUCCESSFUL_FILE)) {
                            def lastBuild = readFile(env.LAST_SUCCESSFUL_FILE).trim()
                            def lastImage = "${env.APP_NAME}:${lastBuild}"
                            echo "🔄 Откатываемся к образу: ${lastImage}"

                            sh """
                                # --format нужен из-за Docker Desktop (Windows)
                                FOUND=\$(docker images --format '{{.Repository}}:{{.Tag}}' \
                                    | grep -x '${lastImage}' || true)

                                if [ -n "\$FOUND" ]; then
                                    docker run -d \
                                        -p ${env.CONTAINER_PORT}:${env.APP_INTERNAL_PORT} \
                                        --name ${env.CONTAINER_NAME} \
                                        ${lastImage}
                                    echo "✓ Rollback выполнен: запущен ${lastImage}"
                                else
                                    echo "⚠ Образ ${lastImage} не найден локально, rollback невозможен"
                                fi
                            """
                        } else {
                            echo "⚠ Файл ${env.LAST_SUCCESSFUL_FILE} не найден — первая сборка, откатиться некуда"
                        }

                        error("❌ Pipeline FAILED: Health check не прошёл")
                    }
                }
            }
        }

        // ══════════════════════════════════════════════════════
        // Stage 5: Rollback Only
        // Запускается ТОЛЬКО если ROLLBACK_ONLY = true.
        // Читает last_successful_build.txt и поднимает ту версию.
        // ══════════════════════════════════════════════════════
        stage('Rollback') {
            when {
                expression { params.ROLLBACK_ONLY == true }
            }
            steps {
                echo "🔄 Режим ROLLBACK_ONLY — ручной откат на предыдущую версию"
                script {
                    if (!fileExists(env.LAST_SUCCESSFUL_FILE)) {
                        error("❌ Rollback невозможен: файл ${env.LAST_SUCCESSFUL_FILE} не найден. Нет ни одной успешной сборки.")
                    }

                    def lastBuild = readFile(env.LAST_SUCCESSFUL_FILE).trim()
                    def lastImage = "${env.APP_NAME}:${lastBuild}"
                    echo "🔄 Откатываемся к образу: ${lastImage}"

                    sh """
                        FOUND=\$(docker images --format '{{.Repository}}:{{.Tag}}' \
                            | grep -x '${lastImage}' || true)

                        if [ -z "\$FOUND" ]; then
                            echo "❌ Образ ${lastImage} не найден локально"
                            exit 1
                        fi

                        docker stop ${env.CONTAINER_NAME} 2>/dev/null || true
                        docker rm   ${env.CONTAINER_NAME} 2>/dev/null || true

                        docker run -d \
                            -p ${env.CONTAINER_PORT}:${env.APP_INTERNAL_PORT} \
                            --name ${env.CONTAINER_NAME} \
                            ${lastImage}

                        echo "✓ Rollback выполнен: запущен ${lastImage}"
                    """
                }
            }
        }
    }

    post {
        always {
            echo "🧹 Cleanup — подчищаем за собой"
            sh "rm -rf DevOps/report-service/venv 2>/dev/null || true"
        }
        success {
            echo "✅ Pipeline SUCCESS — сборка ${env.BUILD_NUMBER} успешна, порт ${env.CONTAINER_PORT}"
        }
        failure {
            echo "❌ Pipeline FAILED — проверьте логи выше"
        }
    }
}